                      },
                      "spec": {
                        "dataset": "house_prices",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n    p.lat,\n    p.lng,\n    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY t.price) AS median_price,\n    t.postcode\nFROM transactions t\nJOIN postcodes p ON t.postcode = p.postcode\nWHERE t.ppd_type = 'A'\n  AND t.record_status = 'A'\n  AND t.price > 0\n  AND t.county = 'GREATER LONDON'\n  AND t.district IN ($borough)\n  AND t.tenure IN ($tenure)\n  AND t.new_build IN ($new_build)\n  AND t.property_type IN ($property_type)\n  AND t.date >= NOW() - INTERVAL '2 years'\nGROUP BY p.lat, p.lng, t.postcode\nHAVING COUNT(*) > 3;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
