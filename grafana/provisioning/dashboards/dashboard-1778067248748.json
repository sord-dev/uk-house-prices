                      "spec": {
                        "dataset": "house_prices",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n    district,\n    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY price) AS median_price,\n    ROUND(CAST(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY price) AS numeric) / $salary::numeric, 1) AS salary_multiple\nFROM transactions\nWHERE ppd_type = 'A'\n  AND record_status = 'A'\n  AND price > 0\n  AND county = 'GREATER LONDON'\n  AND district IN ($borough)\n  AND tenure IN ($tenure)\n  AND property_type IN ($property_type)\n  AND new_build IN ($new_build)\n  AND date >= NOW() - INTERVAL '2 years'\nGROUP BY district\nHAVING COUNT(*) > 50\nORDER BY salary_multiple ASC;",
                        "sql": {
