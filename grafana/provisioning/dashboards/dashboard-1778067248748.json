                        "rawQuery": true,
                        "rawSql": "SELECT\n    district,\n    ROUND(100.0 * SUM(CASE WHEN tenure = 'F' THEN 1 ELSE 0 END) / COUNT(*), 1) AS freehold_pct\nFROM transactions\nWHERE ppd_type = 'A'\n  AND tenure IN ($tenure)\n  AND property_type IN ($property_type)\n  AND new_build IN ($new_build)\n  AND record_status = 'A'\n  AND county = 'GREATER LONDON'\n  AND date >= NOW() - INTERVAL '2 years'\nGROUP BY district\nHAVING COUNT(*) > 50\nORDER BY freehold_pct DESC;",
