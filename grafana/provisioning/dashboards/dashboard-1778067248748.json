      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Affordability by Borough (Salary Multiple)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
