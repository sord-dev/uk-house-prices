      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "YoY Price Change %",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "dfk662ru90ykge"
                      },
                      "spec": {
                        "dataset": "house_prices",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n    district,\n    ROUND(CAST(100.0 * (current_median - prev_median) / prev_median AS numeric), 1) AS yoy_change_pct\nFROM (\n    SELECT\n        district,\n        PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY price) \n            FILTER (WHERE date >= '2025-01-01') AS current_median,\n        PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY price) \n            FILTER (WHERE date BETWEEN '2024-01-01' AND '2025-01-01') AS prev_median\n    FROM transactions\n    WHERE ppd_type = 'A'\n      AND record_status = 'A'\n      AND county IN ($county)\n      AND tenure IN ($tenure)\n      AND property_type IN ($property_type)\n      AND new_build IN ($new_build)\n    GROUP BY district\n    HAVING COUNT(*) > 20\n) sub\nWHERE prev_median IS NOT NULL \n  AND current_median IS NOT NULL\nORDER BY yoy_change_pct DESC;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
