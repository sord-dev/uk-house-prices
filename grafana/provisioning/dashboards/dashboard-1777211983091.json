                      },
                      "spec": {
                        "dataset": "house_prices",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n    DATE_TRUNC('year', date) AS time,\n    county,\n    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY price) AS median_price\nFROM transactions\nWHERE ppd_type = 'A'\n  AND record_status = 'A'\n  AND price > 0\n  AND county != 'GREATER LONDON'\n  AND county IS NOT NULL\n  AND county IN ($county)\n  AND tenure IN ($tenure)\n  AND property_type IN ($property_type)\n  AND new_build IN ($new_build)\nGROUP BY DATE_TRUNC('year', date), county\nORDER BY time, county;",
                        "sql": {
